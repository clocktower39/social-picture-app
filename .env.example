# Backend API URL. Leave blank to use the auto-detected local dev backend
# (same host as the frontend, port 3003). Set this to your deployed backend
# URL when building for production.
#
# Examples:
#   VITE_API_URL=https://social-picture-app.herokuapp.com
#   VITE_API_URL=https://api.your-domain.com
#
# When unset AND the build mode is "production", the app falls back to
# https://social-picture-app.herokuapp.com (configured in vite.config.js).
VITE_API_URL=
